# Node Dependencies (Hem ana dizindeki hem de alt klasörlerdeki tüm node_modules'ları engeller)
node_modules/

# Environment Variables (Şifrelerin olduğu dosyaları gizler, ama .env.example'ı yükler)
.env
.env.*
!.env.example

# Build Outputs (React derlendiğinde oluşan ağır klasörler)
dist/
build/

# Mac OS System Files (Mac'in klasörlere otomatik koyduğu gereksiz gizli dosyalar)
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*